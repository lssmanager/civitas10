{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/validate-civitas-visual.mjs && node scripts/validate-tailwind-semantic-contract.mjs && node scripts/design-system/validate-intake-boundary.mjs && node scripts/design-system/validate-provenance.mjs",
    "lint": "eslint .",
    "test": "node --test \"src/**/*.contract.test.mjs\"",
    "preview": "vite preview",
    "validate:visual-backbone": "node scripts/validate-civitas-backbone.mjs",
    "validate:visual-contract": "node ../scripts/authorization/validate-visual-contract.js",
    "validate:frontend-authz": "node ../scripts/authorization/validate-frontend-authz.js",
    "validate:tailwind-contract": "node scripts/validate-tailwind-semantic-contract.mjs",
    "design:intake:map": "node scripts/design-system/map-tailwind-plus-palette.mjs",
    "design:provenance:check": "node scripts/design-system/validate-provenance.mjs",
    "design:intake:check": "node scripts/design-system/validate-intake-boundary.mjs"
  },
  "dependencies": {
    "@logto/react": "^4.0.3",
    "@tabler/icons-react": "^3.44.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/postcss": "4.3.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.5.16",
    "tailwindcss": "4.3.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0"
  },
  "overrides": {
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.13"
    },
    "ajv": "6.14.0"
  }
}
