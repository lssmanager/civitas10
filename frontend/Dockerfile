FROM node:22-alpine

WORKDIR /app

ARG VITE_LOGTO_ENDPOINT
ARG VITE_LOGTO_APP_ID
ARG VITE_API_BASE_URL
ARG VITE_API_RESOURCE_INDICATOR
ARG VITE_APP_REDIRECT_URI
ARG VITE_APP_SIGNOUT_REDIRECT_URI

ENV VITE_LOGTO_ENDPOINT=$VITE_LOGTO_ENDPOINT
ENV VITE_LOGTO_APP_ID=$VITE_LOGTO_APP_ID
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_API_RESOURCE_INDICATOR=$VITE_API_RESOURCE_INDICATOR
ENV VITE_APP_REDIRECT_URI=$VITE_APP_REDIRECT_URI
ENV VITE_APP_SIGNOUT_REDIRECT_URI=$VITE_APP_SIGNOUT_REDIRECT_URI

COPY package*.json ./
RUN npm install --include=dev

COPY . .
RUN npm run build
RUN npm install -g serve

EXPOSE 4173
CMD ["serve", "-s", "dist", "-l", "4173"]
