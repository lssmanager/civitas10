PORT=3000
NODE_ENV=development
DATABASE_URL=postgres://civitas:change-me@your-postgres-host:5432/civitas
REDIS_URL=redis://your-redis-host:6379/0
SERVICE_URL_WORKER=http://worker:3002

LOGTO_API_RESOURCE_INDICATOR=https://api.civitas.example
LOGTO_ENDPOINT=https://your-logto-endpoint
LOGTO_ISSUER=https://your-logto-endpoint/oidc
LOGTO_JWKS_URL=https://your-logto-endpoint/oidc/jwks
LOGTO_MANAGEMENT_API_TOKEN_ENDPOINT=https://your-logto-endpoint/oidc/token
LOGTO_MANAGEMENT_API_APPLICATION_ID=your-management-app-id
LOGTO_MANAGEMENT_API_APPLICATION_SECRET=your-management-app-secret
LOGTO_MANAGEMENT_API_RESOURCE=https://default.logto.app/api

CIVITAS_BOOTSTRAP_OWNER_LOGTO_USER_ID=logto-user-id-for-first-owner
CIVITAS_BOOTSTRAP_OWNER_ENABLED=true
CIVITAS_ALLOWED_ORG_USER_GLOBAL_ROLES=
LOGTO_ENABLE_ADMIN_PASSWORD_RESET=false
LOGTO_VERSION=1.40.1

BULLMQ_PREFIX=civitas
BULLMQ_QUEUE_NAMES=priority_commands,background_events
WORKER_PORT=3002
WORKER_CONCURRENCY=1
WORKER_JOB_ATTEMPTS=3
WORKER_JOB_BACKOFF_MS=5000
DATABASE_POOL_MAX=10

LOGTO_JWKS_TIMEOUT_MS=5000
LOGTO_JWT_VERIFY_TIMEOUT_MS=6000
LOGTO_MANAGEMENT_TIMEOUT_MS=8000
DATABASE_HEALTH_TIMEOUT_MS=5000
REDIS_HEALTH_TIMEOUT_MS=3000
DATABASE_WAIT_TIMEOUT_MS=30000
DATABASE_WAIT_INTERVAL_MS=1000
DATABASE_CONNECT_TIMEOUT_MS=5000
RUN_MIGRATIONS_ON_STARTUP=false
ENABLE_QUEUE_RECONCILER=true
ENABLE_DB_POLL_EXECUTION=false
QUEUE_RECONCILER_INTERVAL_MS=30000
