{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://civitas.local/contracts/modules/module-manifest-v2.schema.json",
  "title": "Civitas Module Manifest v2",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "version",
    "kind",
    "status",
    "deploymentMode",
    "businessBoundary",
    "ownership",
    "dataOwnership",
    "capabilities",
    "dependencies",
    "contributions",
    "compatibility",
    "lifecycle"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "civitas-module-manifest/v2"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "kind": {
      "enum": [
        "business"
      ]
    },
    "status": {
      "enum": [
        "proposed",
        "planned",
        "active",
        "deprecated",
        "removed"
      ]
    },
    "deploymentMode": {
      "enum": [
        "embedded",
        "federated"
      ]
    },
    "businessBoundary": {
      "type": "string"
    },
    "ownership": {
      "$ref": "#/$defs/ownership",
      "additionalProperties": false
    },
    "dataOwnership": {
      "type": "object",
      "required": [
        "owner",
        "transactionalSystem"
      ],
      "additionalProperties": false,
      "properties": {
        "owner": {
          "type": "string"
        },
        "transactionalSystem": {
          "type": "string"
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "moduleId"
        ],
        "additionalProperties": false,
        "properties": {
          "moduleId": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "optional": {
            "type": "boolean"
          }
        }
      }
    },
    "contributions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contribution",
        "additionalProperties": false
      }
    },
    "compatibility": {
      "type": "object",
      "required": [
        "policy",
        "compatible"
      ],
      "additionalProperties": false,
      "properties": {
        "policy": {
          "type": "string"
        },
        "compatible": {
          "type": "boolean"
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": [
        "supportsTenantLifecycle",
        "storesTenantInstallationState"
      ],
      "additionalProperties": false,
      "properties": {
        "supportsTenantLifecycle": {
          "type": "boolean"
        },
        "storesTenantInstallationState": {
          "const": false
        }
      }
    },
    "federated": {
      "type": "object",
      "required": [
        "runtimeContractVersion",
        "audience",
        "serviceIdentityRequired",
        "uiContractVersion",
        "uiEntryRef",
        "compatibilityPolicy",
        "productSurface"
      ],
      "additionalProperties": false,
      "properties": {
        "runtimeContractVersion": {
          "type": "string"
        },
        "audience": {
          "type": "string"
        },
        "serviceIdentityRequired": {
          "const": true
        },
        "uiContractVersion": {
          "type": "string"
        },
        "uiEntryRef": {
          "type": "string"
        },
        "compatibilityPolicy": {
          "type": "string"
        },
        "productSurface": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "ownership": {
      "type": "object",
      "required": [
        "businessOwner",
        "capabilityOwner",
        "dataOwner",
        "publicApiOwner",
        "runtimeOwner",
        "uiContributionOwner"
      ],
      "additionalProperties": false,
      "properties": {
        "businessOwner": {
          "type": "string"
        },
        "capabilityOwner": {
          "type": "string"
        },
        "dataOwner": {
          "type": "string"
        },
        "publicApiOwner": {
          "type": "string"
        },
        "runtimeOwner": {
          "type": "string"
        },
        "uiContributionOwner": {
          "type": "string"
        }
      }
    },
    "contribution": {
      "type": "object",
      "required": [
        "type",
        "version",
        "owner",
        "artifact",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": [
            "api-openapi",
            "ui",
            "screen-action",
            "navigation",
            "permission-catalog",
            "event",
            "mcp",
            "runtime-contract"
          ]
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
        },
        "owner": {
          "type": "string"
        },
        "artifact": {
          "type": "string"
        },
        "status": {
          "enum": [
            "planned",
            "compatible",
            "deprecated"
          ]
        },
        "contractVersion": {
          "type": "string"
        }
      }
    }
  }
}
