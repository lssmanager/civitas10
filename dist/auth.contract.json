{
  "logto": {
    "issuer": "https://auth.didaxus.com",
    "apiResource": "https://civitas.didaxus.com/api",
    "managementApi": "https://auth.didaxus.com",
    "organizationAudiencePrefix": "urn:logto:organization:"
  },
  "api": {
    "publicUrl": "https://civitas.didaxus.com/api"
  },
  "auth": {
    "global": {
      "ownerRole": "owner_global",
      "globalRoles": [
        "owner_global"
      ],
      "permissions": {
        "ownerProfileRead": "owner.profile.read",
        "ownerOrganizationsRead": "owner.organizations.read",
        "ownerOrganizationsCreate": "owner.organizations.create",
        "ownerRuntimeRead": "owner.runtime.read",
        "ownerRuntimeOperationsExecute": "owner.runtime.operations.execute",
        "ownerWorkerQueuesRead": "owner.worker_queues.read"
      }
    },
    "organization": {
      "reservedResource": "organization",
      "documentPermissions": {
        "documentsRead": "org.documents.read",
        "documentsCreate": "org.documents.create"
      },
      "roles": {
        "admin": "organization_admin",
        "member": "organization_member"
      }
    },
    "invariants": [
      "single_url_resource_indicator",
      "api_resource_matches_public_api_url",
      "global_tokens_must_not_include_organization_context",
      "organization_tokens_must_stay_organization_scoped"
    ]
  }
}
