{
  "name": "civitas10-workspace",
  "private": true,
  "scripts": {
    "authz:naming:report": "node scripts/authorization/validate-authz-naming.js --report",
    "authz:naming:check": "node scripts/authorization/validate-authz-naming.js --check",
    "test:authz:naming": "node --test backend/test/authorization-naming-contract.test.js",
    "logto:authz": "node scripts/logto/cli.js",
    "logto:authz:contract-check": "node scripts/logto/contract-check.js",
    "test:logto:authz": "node --test backend/test/logto-authz-bootstrap.test.js",
    "authz:scope-contract-check": "node scripts/authorization/check-scope-only.js && node --test backend/test/foundation-authorization-middleware.test.js backend/test/authz-scope-delegation-contract.test.js",
    "authz:delegation-contract-check": "node --test backend/test/authz-scope-delegation-contract.test.js",
    "authz:policy-contract-check": "node scripts/authorization/check-policy-runtime.js && node --test backend/test/authz-policy-contract.test.js backend/test/governance-operation-registry-contract.test.js",
    "authz:tenant-contract-check": "node scripts/authorization/check-tenant-routes.js && node --test backend/test/authz-tenant-entitlement-contract.test.js",
    "authz:entitlement-contract-check": "node scripts/authorization/check-entitlement-overlay.js && node --test backend/test/authz-tenant-entitlement-contract.test.js",
    "test": "npm run authz:naming:check && npm run logto:authz:contract-check && npm run authz:scope-contract-check && npm run authz:delegation-contract-check && npm run authz:policy-contract-check && npm run authz:tenant-contract-check && npm run authz:entitlement-contract-check",
    "taxonomy:contract-check": "node scripts/taxonomy/contract-check.js && node --test backend/test/authz-taxonomy-contract.test.js",
    "taxonomy:migration-check": "node scripts/taxonomy/migration-check.js",
    "organization-structure:contract-check": "node scripts/organization-structure-contract-check.js && node --test backend/test/authz-organization-structure-contract.test.js",
    "organization-structure:migration-check": "node scripts/organization-structure-migration-check.js",
    "authz:data-scope-contract-check": "node scripts/authz-data-scope-contract-check.js && node --test backend/test/authz-data-scope-contract.test.js",
    "authz:data-scope-migration-check": "node scripts/authz-data-scope-migration-check.js",
    "organization-structure:data-scope-integration-check": "node scripts/organization-structure-data-scope-integration-check.js && node --test backend/test/authz-organization-structure-data-scope-integration.test.js",
    "organization-structure:reconciliation-check": "node scripts/organization-structure-reconciliation-check.js",
    "authz:runtime-contract-check": "node scripts/authorization/check-runtime-contract.js && node --test backend/test/authz-runtime-consistency-contract.test.js",
    "authz:diagnostics-contract-check": "node --test backend/test/authz-diagnostics-contract.test.js",
    "check:management-level-authz": "node scripts/authorization/check-management-level-is-not-authz-input.js"
  }
}
